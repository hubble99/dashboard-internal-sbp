# Dashboard SBP — Environment Variables
# Salin ke ".env" dan isi nilainya. JANGAN commit file .env ke git!

# ─────────────────────────────────────────────────
# DATABASE (NeonDB)
# URL pooler → untuk runtime queries (via PgBouncer)
# URL non-pooler → untuk migrasi Prisma
# ─────────────────────────────────────────────────

DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-polished-truth-a11j2pjk-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15

DIRECT_DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-polished-truth-a11j2pjk.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ─────────────────────────────────────────────────
# KEAMANAN
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────

JWT_SECRET=ganti_dengan_random_string_panjang_minimal_64_karakter

# ─────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────

NODE_ENV=production
PORT=3000

# ─────────────────────────────────────────────────
# CORS — URL frontend Vercel Anda
# Contoh: https://dashboard-sbp.vercel.app
# ─────────────────────────────────────────────────

CORS_ORIGINS=https://dashboard-sbp.vercel.app

# ─────────────────────────────────────────────────
# MOCK API (sementara, sampai SBP API tersedia)
# Di Railway: isi dengan URL Railway backend Anda sendiri
# Contoh: https://dashboard-sbp-backend.up.railway.app/mock-api
# ─────────────────────────────────────────────────

MOCK_API_BASE_URL=https://YOUR-BACKEND.up.railway.app/mock-api
